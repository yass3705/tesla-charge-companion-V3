{
  "manifest_version": 2,
  "name": "Tesla Charge Companion Updater",
  "version": "2.0.0",
  "description": "Compagnon Firefox de Tesla Charge Companion V4.",
  "permissions": [
    "tabs",
    "downloads",
    "storage",
    "*://www.tesla.com/*"
  ],
  "browser_action": {
    "default_title": "Mettre à jour Tesla",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "applications": {
    "gecko": {
      "id": "tesla-charge-updater@yass3705.local"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.github.io/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}